# Backlot Unraid deploy — copy to deploy/.env and fill in.
#
# Compose auto-loads deploy/.env when you pass -f deploy/docker-compose.unraid.yml
# (the env file is read from the compose file's directory). Never commit deploy/.env.

# ── Cloudflare tunnel ────────────────────────────────────────────────────────
# The EXISTING backlot tunnel token (no reissue). Required for the real deploy.
# LEAVE THIS EMPTY for local Part A verification: a real token here, if cloudflared
# ever started on your machine, would repoint the production hostnames at it.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Backend secrets (public box — do NOT leave as dev values) ─────────────────
# Genesys sends this as X-API-Key on every /gx call; the web container sends the
# same value (mapped to BACKLOT_API_KEY) to reach the api internally.
API_KEY=change-me-strong-key

# Admin UI + scenario controls (/admin/*). A separate trust domain from API_KEY.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-admin-password

# ── Tenant ───────────────────────────────────────────────────────────────────
# TENANT selects the web brand; DEFAULT_TENANT is the api's fallback when a
# request carries no X-Tenant header. Keep them aligned for a single-tenant box.
TENANT=northwind
DEFAULT_TENANT=northwind

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=backlot
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=backlot

# Host path backing the Postgres data (a BIND mount, for visibility + backup).
# Unraid: put it on the cache-only appdata share.
#   /mnt/user/appdata/backlot/pgdata            (via the FUSE user share)
#   /mnt/cache/appdata/backlot/pgdata           (direct pool path, bypasses FUSE)
# Local Part A verification: a local dir, e.g. ./deploy/.data/pgdata
PGDATA_PATH=/mnt/user/appdata/backlot/pgdata

# ── Build contexts (side-by-side repos) ──────────────────────────────────────
# Defaults assume  <parent>/backlot  and  <parent>/backlot-web  side by side.
# Paths resolve relative to the compose file's directory (backlot/deploy/), so
# the sibling web repo is two levels up. Override only if your layout differs.
# API_CONTEXT=..
# WEB_CONTEXT=../../backlot-web

# ── Optional ─────────────────────────────────────────────────────────────────
# APP_ENV=production
# LOG_LEVEL=INFO
