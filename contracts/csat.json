{
  "name": "Backlot - Write CSAT",
  "integrationType": "custom-rest-actions",
  "actionType": "custom",
  "secure": false,
  "config": {
    "request": {
      "requestUrlTemplate": "https://backlot-api.krishharness.com/gx/csat",
      "requestType": "POST",
      "headers": {
        "X-API-Key": "${credentials.apiKey}",
        "Content-Type": "application/json"
      },
      "requestTemplate": "{\"identifier\": \"${esc.jsonString(input.identifier)}\",\"score\": ${input.score},\"comment\": \"${esc.jsonString(input.comment)}\",\"conversation_ref\": \"${esc.jsonString(input.conversation_ref)}\"}"
    },
    "response": {
      "translationMap": {},
      "translationMapDefaults": {},
      "successTemplate": "${rawResult}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "Backlot - Write CSAT input",
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Raw identifier: ANI/phone (E.164 or national), email, or account number. Normalized server-side, so an unencoded '+' is tolerated."
          },
          "score": {
            "type": "integer",
            "description": "1\u20135."
          },
          "comment": {
            "type": "string",
            "description": "Free text."
          },
          "conversation_ref": {
            "type": "string",
            "description": "Genesys conversation id, for correlation."
          }
        },
        "required": [
          "identifier",
          "score"
        ],
        "additionalProperties": false
      }
    },
    "output": {
      "successSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "CsatOut output",
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "True when the satisfaction score was accepted."
          },
          "party_id": {
            "type": "string",
            "description": "Internal subscriber id. Never read it aloud."
          },
          "stored": {
            "type": "boolean",
            "description": "True when the score was persisted."
          }
        },
        "required": [
          "ok",
          "party_id",
          "stored"
        ],
        "additionalProperties": true
      }
    }
  }
}
