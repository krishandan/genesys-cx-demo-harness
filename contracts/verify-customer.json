{
  "name": "Backlot - Verify Customer",
  "integrationType": "custom-rest-actions",
  "actionType": "custom",
  "secure": false,
  "config": {
    "request": {
      "requestUrlTemplate": "https://backlot-api.krishharness.com/gx/verify-customer",
      "requestType": "POST",
      "headers": {
        "X-API-Key": "${credentials.apiKey}",
        "Content-Type": "application/json"
      },
      "requestTemplate": "{\"identifier\": \"${esc.jsonString(input.identifier)}\",\"factor_type\": \"${esc.jsonString(input.factor_type)}\",\"factor_value\": \"${esc.jsonString(input.factor_value)}\"}"
    },
    "response": {
      "translationMap": {},
      "translationMapDefaults": {},
      "successTemplate": "${rawResult}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "Backlot - Verify Customer input",
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Identifier of the subscriber to verify."
          },
          "factor_type": {
            "type": "string",
            "description": "Factor to check: dob | zip | pin | last4."
          },
          "factor_value": {
            "type": "string",
            "description": "The value the caller supplied. Compared as a hash."
          }
        },
        "required": [
          "factor_type",
          "factor_value",
          "identifier"
        ],
        "additionalProperties": false
      }
    },
    "output": {
      "successSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "VerifyCustomerOut output",
        "type": "object",
        "properties": {
          "verified": {
            "type": "boolean",
            "description": "True only when the supplied factor matched. If false, identity is not confirmed \u2014 do not disclose or change account details."
          },
          "party_id": {
            "type": "string",
            "description": "Internal subscriber id, empty unless verified. Never read it aloud."
          },
          "masked_name": {
            "type": "string",
            "description": "The subscriber's name with most letters masked, e.g. 'A*** C***'. Safe to use to confirm who verified without reciting their full name."
          }
        },
        "required": [
          "masked_name",
          "party_id",
          "verified"
        ],
        "additionalProperties": true
      }
    }
  }
}
