{
  "name": "Backlot - Network Telemetry Feed",
  "integrationType": "custom-rest-actions",
  "secure": false,
  "config": {
    "request": {
      "requestUrlTemplate": "https://backlot-api.krishharness.com/gx/telemetry?identifier=${input.identifier}",
      "requestType": "GET",
      "headers": {
        "X-API-Key": "${credentials.apiKey}",
        "X-Tenant": "${input.tenant}"
      },
      "requestTemplate": "${input.rawRequest}"
    },
    "response": {
      "translationMap": {},
      "translationMapDefaults": {},
      "successTemplate": "${rawResult}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "Backlot - Network Telemetry Feed input",
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Raw identifier: ANI/phone (E.164 or national), email, or account number. Normalized server-side, so an unencoded '+' is tolerated."
          },
          "tenant": {
            "type": "string",
            "description": "Tenant slug. Leave empty to use the API's default tenant."
          }
        },
        "required": [
          "identifier"
        ],
        "additionalProperties": false
      }
    },
    "output": {
      "successSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "TelemetryOut feed",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "party_id": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "fault_type": {
              "type": "string"
            },
            "primary_target": {
              "type": "string"
            },
            "primary_target_kind": {
              "type": "string"
            },
            "primary_target_label": {
              "type": "string"
            },
            "recommended_action": {
              "type": "string"
            },
            "conversation_ref": {
              "type": "string"
            },
            "occurred_at": {
              "type": "string"
            }
          },
          "required": [
            "conversation_ref",
            "fault_type",
            "kind",
            "occurred_at",
            "party_id",
            "primary_target",
            "primary_target_kind",
            "primary_target_label",
            "recommended_action"
          ],
          "additionalProperties": true
        }
      }
    }
  }
}
