{
  "name": "Backlot - Network Telemetry Feed",
  "integrationType": "custom-rest-actions",
  "actionType": "custom",
  "secure": false,
  "config": {
    "request": {
      "requestUrlTemplate": "https://backlot-api.krishharness.com/gx/telemetry?identifier=${esc.url(input.identifier)}",
      "requestType": "GET",
      "headers": {
        "X-API-Key": "${credentials.apiKey}"
      },
      "requestTemplate": "${input.rawRequest}"
    },
    "response": {
      "translationMap": {},
      "translationMapDefaults": {},
      "successTemplate": "${rawResult}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "Backlot - Network Telemetry Feed input",
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Raw identifier: ANI/phone (E.164 or national), email, or account number. Normalized server-side, so an unencoded '+' is tolerated."
          }
        },
        "required": [
          "identifier"
        ],
        "additionalProperties": false
      }
    },
    "output": {
      "successSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "TelemetryOut feed",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "party_id": {
              "type": "string",
              "description": "Internal subscriber id the event belongs to."
            },
            "kind": {
              "type": "string",
              "description": "Event kind, e.g. network.degraded."
            },
            "fault_type": {
              "type": "string",
              "description": "The fault detected when this event was raised."
            },
            "primary_target": {
              "type": "string",
              "description": "Opaque id of the affected thing. Never read it aloud."
            },
            "primary_target_kind": {
              "type": "string",
              "description": "What the target is: device, ap, or gateway."
            },
            "primary_target_label": {
              "type": "string",
              "description": "Human name of the affected thing."
            },
            "recommended_action": {
              "type": "string",
              "description": "The verb that would remedy this fault."
            },
            "conversation_ref": {
              "type": "string",
              "description": "Genesys conversation id, when the event came from one."
            },
            "occurred_at": {
              "type": "string",
              "description": "ISO-8601 timestamp of when the event was raised."
            }
          },
          "required": [
            "conversation_ref",
            "fault_type",
            "kind",
            "occurred_at",
            "party_id",
            "primary_target",
            "primary_target_kind",
            "primary_target_label",
            "recommended_action"
          ],
          "additionalProperties": true
        }
      }
    }
  }
}
