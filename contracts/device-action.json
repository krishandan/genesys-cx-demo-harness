{
  "name": "Backlot - Device Action",
  "integrationType": "custom-rest-actions",
  "actionType": "custom",
  "secure": false,
  "config": {
    "request": {
      "requestUrlTemplate": "https://backlot-api.krishharness.com/gx/device-action",
      "requestType": "POST",
      "headers": {
        "X-API-Key": "${credentials.apiKey}",
        "Content-Type": "application/json"
      },
      "requestTemplate": "{\"identifier\": \"$esc.jsonString(\"${input.identifier}\")\",\"action\": \"$esc.jsonString(\"${input.action}\")\",\"target\": \"$esc.jsonString(\"${input.target}\")\",\"params\": \"$esc.jsonString(\"${input.params}\")\"}"
    },
    "response": {
      "translationMap": {},
      "translationMapDefaults": {},
      "successTemplate": "${rawResult}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "Backlot - Device Action input",
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Raw identifier: ANI/phone (E.164 or national), email, or account number. Normalized server-side, so an unencoded '+' is tolerated."
          },
          "action": {
            "type": "string",
            "description": "band-steer | reboot-extender | reboot-ap"
          },
          "target": {
            "type": "string",
            "description": "device_id or ap_id, taken from net-diagnostics primary_target."
          },
          "params": {
            "type": "string",
            "description": "Optional JSON object as a string, e.g. '{\"band\":\"5\"}'. Leave empty for the default behaviour."
          }
        },
        "required": [
          "action",
          "identifier",
          "target"
        ],
        "additionalProperties": false
      }
    },
    "output": {
      "successSchema": {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "DeviceActionOut output",
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "True when the action was applied. False means nothing changed."
          },
          "action": {
            "type": "string",
            "description": "The verb that was run."
          },
          "target": {
            "type": "string",
            "description": "The id that was acted on."
          },
          "result_summary": {
            "type": "string",
            "description": "Plain-English description of what changed, safe to paraphrase to the customer. On failure, why it did not run."
          },
          "fault_cleared": {
            "type": "boolean",
            "description": "True when the fault this action targeted is now gone. If false, a fault remains \u2014 call net-diagnostics again to see what is left."
          }
        },
        "required": [
          "action",
          "fault_cleared",
          "ok",
          "result_summary",
          "target"
        ],
        "additionalProperties": true
      }
    }
  }
}
