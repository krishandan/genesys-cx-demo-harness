# Backlot — copy to .env and adjust. 12-factor: no host assumptions in code.

APP_ENV=local
APP_VERSION=0.1.0

# API key required on every /v1 and /gx call via the X-API-Key header.
API_KEY=dev-local-key-change-me

# Admin UI + scenario controls (/admin/*). A SEPARATE trust domain from API_KEY:
# Genesys holds API_KEY and must never be able to stage or reset a demo with it,
# and these credentials must never open /gx. Change both before exposing the tunnel.
ADMIN_USER=admin
ADMIN_PASSWORD=backlot-admin-change-me

# Tenant resolved when a request carries no X-Tenant header.
DEFAULT_TENANT=northwind

# --- Database ---
# The api service reaches Postgres over the compose network by service name.
DATABASE_URL=postgresql+psycopg://backlot:backlot@db:5432/backlot
POSTGRES_USER=backlot
POSTGRES_PASSWORD=backlot
POSTGRES_DB=backlot

# Host path backing the Postgres named volume.
# Local:   ./.data/postgres
# Unraid:  /mnt/user/appdata/backlot/postgres
POSTGRES_DATA_PATH=./.data/postgres

# --- cloudflared ---
# Tunnel token from the Cloudflare Zero Trust dashboard. Leave blank locally;
# the cloudflared service stays inert without it.
CLOUDFLARE_TUNNEL_TOKEN=
